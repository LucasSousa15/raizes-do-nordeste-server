{
  "info": {
    "name": "Raizes do Nordeste API",
    "description": "Colecao para fluxo Auth -> Cardapio -> Pedido -> Pagamento mock -> Fidelidade.\n\nPre-requisitos:\n1. npm run start:dev\n2. npx prisma migrate deploy\n3. npm run db:seed\n\nExecute na ordem das pastas. O login salva accessToken automaticamente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "storeId", "value": "bbbbbbbb-bbbb-4bbb-8bbb-bbbbbbbbbbbb" },
    { "key": "productId", "value": "11111111-1111-4111-8111-111111111111" },
    { "key": "customerId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "customerEmail", "value": "cliente.teste@example.com" },
    { "key": "customerPassword", "value": "Senha@123" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Cadastrar cliente",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cliente Teste\",\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\",\n  \"customerData\": {\n    \"cpf\": \"529.982.247-25\",\n    \"consent\": true,\n    \"consentAt\": \"2026-06-01T12:00:00.000Z\"\n  }\n}"
            },
            "url": "{{baseUrl}}/users"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.user && body.user.id) pm.collectionVariables.set('customerId', body.user.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login valido",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/sign-in"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.expect(body.accessToken).to.be.a('string');",
                  "pm.collectionVariables.set('accessToken', body.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login senha invalida",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"senha-errada\"\n}"
            },
            "url": "{{baseUrl}}/auth/sign-in"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Stores",
      "item": [
        {
          "name": "Listar unidades",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/stores"
          }
        },
        {
          "name": "Cardapio da unidade",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/stores/{{storeId}}/menu"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.expect(body.menu.items).to.be.an('array');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Criar pedido",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"storeId\": \"{{storeId}}\",\n  \"customerId\": \"{{customerId}}\",\n  \"channel\": \"online\",\n  \"items\": [\n    { \"productId\": \"{{productId}}\", \"quantity\": 1 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('orderId', body.order.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Confirmar pagamento",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"confirmPayment\": true,\n  \"simulatePaymentFailure\": false\n}"
            },
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Pagamento recusado",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"confirmPayment\": true,\n  \"simulatePaymentFailure\": true\n}"
            },
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Atualizar status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"shipped\"\n}"
            },
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Listar pedidos por canal",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/orders?channel=online&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "channel", "value": "online" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Cancelar pedido",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Idempotencia aprovar",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"confirmPayment\": true,\n  \"idempotencyKey\": \"approve-postman-1234567890\"\n}"
            },
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Idempotencia rejeitar",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"confirmPayment\": true,\n  \"idempotencyKey\": \"reject-postman-1234567890\"\n}"
            },
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        }
      ]
    },
    {
      "name": "Loyalty",
      "item": [
        {
          "name": "Consultar saldo",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/loyalty/balance"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.expect(pm.response.json().loyalty.points).to.be.a('number');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Resgatar pontos",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"points\": 1\n}"
            },
            "url": "{{baseUrl}}/loyalty/redeem"
          }
        },
        {
          "name": "Historico de pontos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/loyalty/history"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.expect(pm.response.json().loyalty.history).to.be.an('array');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Erros",
      "item": [
        {
          "name": "Listar pedidos sem token",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Listar produtos sem permissao",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/products"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 403', () => pm.response.to.have.status(403));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Criar pedido sem canal",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"storeId\": \"{{storeId}}\",\n  \"customerId\": \"{{customerId}}\",\n  \"items\": [{ \"productId\": \"{{productId}}\", \"quantity\": 1 }]\n}"
            },
            "url": "{{baseUrl}}/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 422', () => pm.response.to.have.status(422));"],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Pedido estoque insuficiente",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"storeId\": \"{{storeId}}\",\n  \"customerId\": \"{{customerId}}\",\n  \"channel\": \"online\",\n  \"items\": [{ \"productId\": \"{{productId}}\", \"quantity\": 99999 }]\n}"
            },
            "url": "{{baseUrl}}/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["pm.test('Status 409', () => pm.response.to.have.status(409));"],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
